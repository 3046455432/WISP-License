---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getAuthUserAsync } from '../lib/auth';
const user = await getAuthUserAsync(Astro.cookies);
if (user) return Astro.redirect('/dashboard');
const error = Astro.url.searchParams.get('error');
---
<Layout title="Registro — WISP License">
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;">
    <div style="width:100%;max-width:460px;">
        <div style="text-align:center;margin-bottom:2rem;">
            <div style="font-size:2.5rem;margin-bottom:0.5rem;">🚀</div>
            <h1 style="font-size:1.75rem;font-weight:900;color:#e2e8f0;margin-bottom:0.5rem;">Crea tu cuenta</h1>
            <p style="color:#64748b;font-size:0.9rem;">Empieza con un trial gratuito de 14 días</p>
        </div>

        {error && (
            <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;padding:0.75rem 1rem;border-radius:0.75rem;font-size:0.875rem;margin-bottom:1rem;text-align:center;">
                {error === 'exists' ? 'Ya existe una cuenta con ese correo.' : error}
            </div>
        )}

        <form method="POST" action="/api/auth/register" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:2rem;display:flex;flex-direction:column;gap:1rem;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div>
                    <label style="display:block;font-size:0.8rem;font-weight:600;color:#94a3b8;margin-bottom:0.4rem;">Nombre completo</label>
                    <input name="fullName" type="text" required
                        style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.75rem;padding:0.7rem 1rem;font-size:0.9rem;outline:none;font-family:inherit;"
                        placeholder="Juan Pérez"/>
                </div>
                <div>
                    <label style="display:block;font-size:0.8rem;font-weight:600;color:#94a3b8;margin-bottom:0.4rem;">Empresa / ISP</label>
                    <input name="companyName" type="text" required
                        style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.75rem;padding:0.7rem 1rem;font-size:0.9rem;outline:none;font-family:inherit;"
                        placeholder="ISP del Norte"/>
                </div>
            </div>
            <div>
                <label style="display:block;font-size:0.8rem;font-weight:600;color:#94a3b8;margin-bottom:0.4rem;">Correo electrónico</label>
                <input name="email" type="email" required
                    style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.75rem;padding:0.7rem 1rem;font-size:0.9rem;outline:none;font-family:inherit;"
                    placeholder="tu@empresa.com"/>
            </div>
            <div>
                <label style="display:block;font-size:0.8rem;font-weight:600;color:#94a3b8;margin-bottom:0.4rem;">Contraseña</label>
                <input name="password" type="password" required minlength="8"
                    style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.75rem;padding:0.7rem 1rem;font-size:0.9rem;outline:none;font-family:inherit;"
                    placeholder="Mínimo 8 caracteres"/>
            </div>
            <div style="background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.2);border-radius:0.75rem;padding:0.75rem 1rem;font-size:0.82rem;color:#a5b4fc;">
                ✅ Al registrarte recibirás un <strong>trial gratuito de 14 días</strong> con acceso a hasta 3 routers. No se requiere tarjeta.
            </div>
            <button type="submit" style="background:#6366f1;color:white;border:none;border-radius:0.75rem;padding:0.85rem;font-weight:700;font-size:0.95rem;cursor:pointer;font-family:inherit;">
                Crear cuenta y comenzar →
            </button>
        </form>

        <p style="text-align:center;margin-top:1.5rem;color:#64748b;font-size:0.875rem;">
            ¿Ya tienes cuenta? <a href="/login" style="color:#a5b4fc;font-weight:600;text-decoration:none;">Inicia sesión</a>
        </p>
    </div>
</div>
</Layout>
