---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getAuthUserAsync, isAdmin } from '../../lib/auth';
import { getSupabaseAdmin } from '../../lib/supabase';

const user = await getAuthUserAsync(Astro.cookies);
if (!user || !isAdmin(user)) return Astro.redirect('/login');

const db = getSupabaseAdmin();
const { data: plans } = await db.from('plans').select('*').order('price_monthly');
---
<Layout title="Admin Planes — WISP License" user={user}>
<div style="max-width:1000px;margin:0 auto;padding:2rem 1rem;">
    <div style="margin-bottom:2rem;">
        <h1 style="font-size:1.75rem;font-weight:900;color:#e2e8f0;">📋 Planes</h1>
        <nav style="display:flex;gap:1rem;margin-top:0.5rem;">
            <a href="/admin/licencias" style="color:#64748b;font-size:0.875rem;font-weight:600;text-decoration:none;">Licencias</a>
            <a href="/admin/planes" style="color:#a5b4fc;font-size:0.875rem;font-weight:700;text-decoration:none;border-bottom:2px solid #6366f1;padding-bottom:2px;">Planes</a>
            <a href="/admin/clientes" style="color:#64748b;font-size:0.875rem;font-weight:600;text-decoration:none;">Clientes</a>
        </nav>
    </div>

    <div style="display:grid;gap:1.5rem;">
        {plans?.map(plan => (
            <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:1.5rem;">
                <form method="POST" action="/api/admin/update-plan" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;align-items:end;">
                    <input type="hidden" name="id" value={plan.id}/>
                    <div>
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;margin-bottom:0.35rem;text-transform:uppercase;">Nombre</label>
                        <input name="name" type="text" value={plan.name} style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.875rem;font-family:inherit;outline:none;"/>
                    </div>
                    <div>
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;margin-bottom:0.35rem;text-transform:uppercase;">Precio/mes ($)</label>
                        <input name="price_monthly" type="number" step="0.01" value={plan.price_monthly} style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.875rem;font-family:inherit;outline:none;"/>
                    </div>
                    <div>
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;margin-bottom:0.35rem;text-transform:uppercase;">Precio/año ($)</label>
                        <input name="price_yearly" type="number" step="0.01" value={plan.price_yearly} style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.875rem;font-family:inherit;outline:none;"/>
                    </div>
                    <div>
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;margin-bottom:0.35rem;text-transform:uppercase;">Max Routers (-1=∞)</label>
                        <input name="max_routers" type="number" value={plan.max_routers} style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.875rem;font-family:inherit;outline:none;"/>
                    </div>
                    <div>
                        <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;margin-bottom:0.35rem;text-transform:uppercase;">Stripe Price ID</label>
                        <input name="stripe_price_id_monthly" type="text" value={plan.stripe_price_id_monthly || ''} placeholder="price_..." style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#e2e8f0;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.875rem;font-family:inherit;outline:none;"/>
                    </div>
                    <div style="display:flex;align-items:end;gap:0.5rem;">
                        <label style="display:flex;align-items:center;gap:0.5rem;color:#94a3b8;font-size:0.85rem;cursor:pointer;">
                            <input name="is_featured" type="checkbox" checked={plan.is_featured} value="true"/>
                            Destacado
                        </label>
                        <label style="display:flex;align-items:center;gap:0.5rem;color:#94a3b8;font-size:0.85rem;cursor:pointer;">
                            <input name="is_active" type="checkbox" checked={plan.is_active} value="true"/>
                            Activo
                        </label>
                        <button type="submit" style="background:#6366f1;color:white;border:none;border-radius:0.5rem;padding:0.5rem 1rem;font-weight:700;font-size:0.8rem;cursor:pointer;font-family:inherit;margin-left:auto;">
                            💾 Guardar
                        </button>
                    </div>
                </form>
            </div>
        ))}
    </div>
</div>
</Layout>
